3:T548,{"@context":"https://schema.org","@graph":[{"@type":"Article","@id":"https://toolfocus.in/blog/css-gradient-tutorial#article","headline":"CSS Gradients: A Complete Guide to Linear, Radial, and Conic Gradients ","description":"Master CSS gradients — linear, radial, conic, and repeating gradients — with practical examples, browser support notes, and design tips you can use today.","datePublished":"2024-12-10","dateModified":"2024-12-10","inLanguage":"en-US","keywords":"css, gradients, design, frontend","articleSection":"Developer","author":{"@type":"Organization","name":"ToolFocus","url":"https://toolfocus.in"},"publisher":{"@type":"Organization","name":"ToolFocus","url":"https://toolfocus.in","logo":{"@type":"ImageObject","url":"https://toolfocus.in/logo.png"}},"image":{"@type":"ImageObject","url":"https://toolfocus.in/og-image.png","width":1200,"height":630},"mainEntityOfPage":{"@type":"WebPage","@id":"https://toolfocus.in/blog/css-gradient-tutorial"}},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://toolfocus.in"},{"@type":"ListItem","position":2,"name":"Blog","item":"https://toolfocus.in/blog"},{"@type":"ListItem","position":3,"name":"CSS Gradients: A Complete Guide to Linear, Radial, and Conic Gradients ","item":"https://toolfocus.in/blog/css-gradient-tutorial"}]}]}7:["id","css-gradient-tutorial","d"]
